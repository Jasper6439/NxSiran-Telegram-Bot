# ── NxSiran Bot 环境变量模板 ─────────────────────────────
# 复制此文件为 .env 并填入实际值

# Telegram Bot Token（必填）
TELEGRAM_TOKEN=

# 管理员 Telegram Chat ID
YOUR_CHAT_ID=0

# AI API 配置
AI_API_BASE=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=minimax/minimax-m2.5:free

# Gemini API（可选）
GEMINI_API_KEY=

# Relay API（可选）
RELAY_API_KEY=

# 数据存储目录
DATA_DIR=/opt/NxSiran/data

# Web 服务器端口
PORT=8080

# 公开访问 URL（用于 Webhook 模式）
PUBLIC_URL=

# 管理员信息
ADMIN_USERNAME=Ulysses

# Qdrant Cloud（向量记忆系统，免费注册 https://cloud.qdrant.io）
QDRANT_URL=
QDRANT_API_KEY=

# GitHub Webhook 自动部署（可选）
GITHUB_WEBHOOK_SECRET=
