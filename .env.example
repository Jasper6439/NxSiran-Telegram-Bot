# ── NxSiran Bot 环境变量模板 ─────────────────────────────
# 复制此文件为 .env 并填入实际值

# Telegram Bot Token（必填）
TELEGRAM_TOKEN=

# 管理员 Telegram Chat ID
YOUR_CHAT_ID=0

# AI API 配置
AI_API_BASE=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=minimax/minimax-m2.5:free

# Gemini API（可选）
GEMINI_API_KEY=

# Relay API（可选）
RELAY_API_KEY=

# 数据存储目录
DATA_DIR=/opt/NxSiran-Telegram-Bot/data

# Web 服务器端口
PORT=8080

# 公开访问 URL（用于 Webhook 模式）
PUBLIC_URL=

# 管理员信息
ADMIN_USERNAME=Ulysses

# GitHub Webhook 自动部署（可选）
GITHUB_WEBHOOK_SECRET=

# ── v1.9.3 新增配置 ─────────────────────────────

# 本地 TTS 服务配置
# 支持: sovits (GPT-SoVITS), cosyvoice, edge (Edge TTS)
TTS_BACKEND=sovits
LOCAL_TTS_URL=http://127.0.0.1:9880

# 图像生成三级路由
# Primary: OpenRouter 免费模型
# Fallback: 商汤 SenseNova
# Backup: SiliconFlow
SENSENOVA_API_KEY=
SILICONFLOW_API_KEY=

# 角色进化系统
EVOLUTION_MODEL=deepseek/deepseek-r1:free
