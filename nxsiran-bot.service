[Unit]
Description=NxSiran Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/NxSiran-Telegram-Bot
EnvironmentFile=/root/NxSiran-Telegram-Bot/.env
ExecStart=/usr/bin/python3 /root/NxSiran-Telegram-Bot/bot.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
